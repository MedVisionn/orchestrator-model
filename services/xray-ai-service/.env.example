# MedScanAI X-Ray AI Service - Environment Variables
# Copy this file to .env and update with your values

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=xray-ai-service
VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, console

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# Model Configuration
# =============================================================================
MODEL_NAME=densenet121-res224-all
MODEL_VERSION=1.0.0
MODEL_PATH=./models
DEVICE=cpu  # cpu, cuda, cuda:0
USE_ONNX=false

# =============================================================================
# Inference Configuration
# =============================================================================
INPUT_SIZE_H=224
INPUT_SIZE_W=224
BATCH_SIZE=1
INFERENCE_TIMEOUT=30
MAX_FILE_SIZE_MB=10

# =============================================================================
# Calibration
# =============================================================================
CALIBRATION_METHOD=temperature_scaling  # temperature_scaling, platt_scaling, isotonic
TEMPERATURE=1.5

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medscan
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Cache (Redis)
# =============================================================================
ENABLE_CACHE=true
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# MLflow Model Registry
# =============================================================================
ENABLE_MLFLOW=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=xray-inference

# =============================================================================
# Monitoring
# =============================================================================
ENABLE_PROMETHEUS=true
METRICS_PORT=9090

# =============================================================================
# Explainability
# =============================================================================
ENABLE_GRADCAM=true
GRADCAM_LAYER=features.denseblock4

# =============================================================================
# Rate Limiting
# =============================================================================
ENABLE_RATE_LIMIT=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=change-me-in-production-use-secrets-manager
ENABLE_AUTH=false

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_REPORT_GENERATION=true
ENABLE_FEEDBACK=true
LOG_PREDICTIONS=true

# =============================================================================
# AWS (if using S3 for models)
# =============================================================================
#AWS_ACCESS_KEY_ID=your_access_key
#AWS_SECRET_ACCESS_KEY=your_secret_key
#AWS_REGION=us-east-1
#S3_BUCKET=medscan-models

# =============================================================================
# Sentry (Error Tracking)
# =============================================================================
#SENTRY_DSN=https://your-sentry-dsn
#SENTRY_ENVIRONMENT=production

# =============================================================================
# OpenTelemetry (Distributed Tracing)
# =============================================================================
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#OTEL_SERVICE_NAME=xray-ai-service
